# -----------------------------------------------------------------------------
# PayDev Hub — environment (copy to .env.local)
# -----------------------------------------------------------------------------

# Demo: mock webhooks (in-memory, no data/webhooks.json) + demo dashboard stats.
# Live: persistent webhooks on disk via lowdb.
NEXT_PUBLIC_USE_MOCK_DATA=true

# When false or unset, webhooks use real persistence (lowdb under /data).
# NEXT_PUBLIC_USE_MOCK_DATA=false

# Future third-party integrations (optional; not wired in demo)
# STRIPE_SECRET_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# NEXT_PUBLIC_APP_URL=http://localhost:3000
